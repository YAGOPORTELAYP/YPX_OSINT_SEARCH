{
  "entities": {
    "Target": {
      "title": "Target",
      "description": "An entity being monitored for intelligence updates.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the target." },
        "query": { "type": "string", "description": "The search query (domain, email, etc.)." },
        "status": { "type": "string", "enum": ["active", "paused"], "description": "Monitoring status." },
        "lastChecked": { "type": "string", "format": "date-time", "description": "Last time the target was scanned." },
        "uid": { "type": "string", "description": "Owner's user ID." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["query", "status", "uid", "createdAt"]
    },
    "Alert": {
      "title": "Alert",
      "description": "A real-time intelligence update for a monitored target.",
      "type": "object",
      "properties": {
        "targetId": { "type": "string", "description": "ID of the monitored target." },
        "title": { "type": "string", "description": "Alert title." },
        "content": { "type": "string", "description": "Alert details." },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "uid": { "type": "string", "description": "Owner's user ID." }
      },
      "required": ["targetId", "title", "content", "severity", "timestamp", "uid"]
    },
    "HistoryItem": {
      "title": "HistoryItem",
      "description": "A record of an intelligence search and its results.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "query": { "type": "string", "description": "The search query." },
        "data": { "type": "object", "description": "The intelligence data (nodes, links, report, sources)." },
        "chatMessages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "text": { "type": "string" }
            },
            "required": ["role", "text"]
          }
        },
        "timestamp": { "type": "string", "format": "date-time" },
        "uid": { "type": "string", "description": "Owner's user ID." }
      },
      "required": ["query", "data", "timestamp", "uid"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback on intelligence results to improve the system.",
      "type": "object",
      "properties": {
        "sourceId": { "type": "string", "description": "ID of the history item or alert." },
        "type": { "type": "string", "enum": ["correction", "error", "praise"] },
        "comment": { "type": "string" },
        "originalData": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["sourceId", "type", "comment", "timestamp", "uid"]
    },
    "LearnedPattern": {
      "title": "LearnedPattern",
      "description": "A summarized lesson learned from feedback or errors.",
      "type": "object",
      "properties": {
        "pattern": { "type": "string" },
        "context": { "type": "string" },
        "weight": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["pattern", "timestamp"]
    }
  },
  "firestore": {
    "/targets/{targetId}": {
      "schema": "Target",
      "description": "Collection of entities being monitored."
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Real-time alerts for monitored entities."
    },
    "/history/{historyId}": {
      "schema": "HistoryItem",
      "description": "Historical intelligence search records."
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback for system improvement."
    },
    "/learned_patterns/{patternId}": {
      "schema": "LearnedPattern",
      "description": "Global knowledge base of learned behaviors."
    }
  }
}
