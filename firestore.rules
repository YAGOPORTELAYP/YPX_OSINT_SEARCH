rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: targets
    // Fields:
    //   - query: string (required)
    //   - status: string (required, enum: active, paused)
    //   - lastChecked: timestamp (optional)
    //   - uid: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: alerts
    // Fields:
    //   - targetId: string (required)
    //   - title: string (required)
    //   - content: string (required)
    //   - severity: string (required, enum: low, medium, high, critical)
    //   - timestamp: timestamp (required)
    //   - uid: string (required, immutable)
    //
    // Collection: history
    // Fields:
    //   - query: string (required)
    //   - data: map (required)
    //   - timestamp: timestamp (required)
    //   - uid: string (required, immutable)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidStatus(status) {
      return status in ['active', 'paused'];
    }

    function isValidSeverity(severity) {
      return severity in ['low', 'medium', 'high', 'critical'];
    }

    // Domain Validators
    function isValidTarget(data) {
      return data.query is string && data.query.size() > 0 && data.query.size() < 256 &&
             isValidStatus(data.status) &&
             data.uid == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidAlert(data) {
      return data.targetId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 256 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             isValidSeverity(data.severity) &&
             data.timestamp is timestamp &&
             data.uid == request.auth.uid;
    }

    function isValidHistory(data) {
      return data.query is string && data.query.size() > 0 && data.query.size() < 512 &&
             data.data is map &&
             (!('chatMessages' in data) || data.chatMessages is list) &&
             data.timestamp is timestamp &&
             data.uid == request.auth.uid;
    }

    // Rules
    match /targets/{targetId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidTarget(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidTarget(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /alerts/{alertId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidAlert(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidAlert(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /history/{historyId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidHistory(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidHistory(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}
